{
  "name": "@pieui/react",
  "version": "0.2.0",
  "description": "Expressive, accessible React components powered by design tokens. Apple-inspired surfaces.",
  "keywords": [
    "react",
    "component-library",
    "design-system",
    "ui",
    "tokens",
    "accessibility"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --external react --external react-dom && node -e \"require('fs').copyFileSync('src/styles.css','dist/styles.css')\"",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@pieui/tokens": "^0.2.0"
  }
}
